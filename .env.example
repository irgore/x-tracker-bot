# ── X Following Tracker Bot ──

# Required: Discord bot token
DISCORD_TOKEN=your_bot_token_here

# Required: Path to X login session file (Playwright storage state)
# Generate with: ./login.sh
X_SESSION=/root/.x-session.json

# Poll interval in seconds (default: 600 = 10 min)
# POLL_INTERVAL=600

# Max scroll depth when scraping /following page (default: 15)
# MAX_SCROLL=15

# State directory (default: ~/.x-tracker-state)
# STATE_DIR=/root/.x-tracker-state

# Database path (default: ~/.x-tracker-state/bot.db)
# DB_PATH=/root/.x-tracker-state/bot.db
