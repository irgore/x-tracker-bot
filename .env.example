# ── X Following Tracker Bot ──
# Required: Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Poll interval in seconds (default: 1800 = 30 min)
# POLL_INTERVAL=1800

# Max scroll depth when scraping /following page (default: 30)
# MAX_SCROLL=30

# State directory (default: ~/.x-tracker-state)
# STATE_DIR=/root/.x-tracker-state

# Database path (default: ~/.x-tracker-state/bot.db)
# DB_PATH=/root/.x-tracker-state/bot.db
